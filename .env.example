# .env.example — copy to .env and fill in values

# Polymarket (required for live trading only)
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Data APIs (all optional — free tiers available)
# TRADIER_API_KEY=          # S&P options implied vol
# FOOTBALL_DATA_API_KEY=    # football-data.org (soccer)

# Bot settings (override config.py defaults)
# TOTAL_BUDGET_USDC=10000
# PAPER_TRADE=true
